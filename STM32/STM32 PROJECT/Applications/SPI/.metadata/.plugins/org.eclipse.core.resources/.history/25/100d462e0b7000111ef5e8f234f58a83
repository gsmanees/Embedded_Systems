#include "stm32f446xx.h"
#include "stm32f446xx_gpio_driver.h"
#include "stm32f446xx_spi_driver.h"

void BMP280_SPI_GPIOInits(void)
{
    GPIO_Handle_t SPIPins;
    GPIO_PeriClockControl(GPIOA, ENABLE);

    SPIPins.pGPIOx = GPIOA;
    SPIPins.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_ALTFN;
    SPIPins.GPIO_PinConfig.GPIO_PinAltFunMode = 5;
    SPIPins.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
    SPIPins.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;
    SPIPins.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;

    SPIPins.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_5; // SCK (D13)
    GPIO_Init(&SPIPins);
    SPIPins.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_6; // MISO (D12)
    GPIO_Init(&SPIPins);
    SPIPins.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_7; // MOSI (D11)
    GPIO_Init(&SPIPins);

    // Configure CSB (PA4) as Output
    SPIPins.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;
    SPIPins.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_4; // CS (A2)
    GPIO_Init(&SPIPins);

    // Pull CS High initially
    GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_4, GPIO_PIN_SET);
}

void BMP280_SPI_Init(void)
{
    SPI_Handle_t SPI1Handle;
    SPI1Handle.pSPIx = SPI1;
    SPI1Handle.SPIConfig.SPI_DeviceMode = SPI_DEVICE_MODE_MASTER;
    SPI1Handle.SPIConfig.SPI_BusConfig = SPI_BUS_CONFIG_FD;
    SPI1Handle.SPIConfig.SPI_SclkSpeed = SPI_SCLK_SPEED_DIV16;
    SPI1Handle.SPIConfig.SPI_DFF = SPI_DFF_8BITS;
    SPI1Handle.SPIConfig.SPI_CPOL = SPI_CPOL_LOW;
    SPI1Handle.SPIConfig.SPI_CPHA = SPI_CPHA_LOW;
    SPI1Handle.SPIConfig.SPI_SSM = SPI_SSM_EN;

    SPI_Init(&SPI1Handle);
    SPI_SSIConfig(SPI1, ENABLE);
    SPI_PeripheralControl(SPI1, ENABLE);
}


uint8_t SPI_Transfer(uint8_t data)
{
    while(!(SPI1->SR & (1 << 1))); // Wait TXE
    SPI1->DR = data;
    while(!(SPI1->SR & (1 << 0))); // Wait RXNE
    return SPI1->DR;
}

void BMP280_WriteRegister(uint8_t reg, uint8_t value)
{
    GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_4, GPIO_PIN_RESET); // CS LOW
    SPI_Transfer(reg & 0x7F); // Write Mode: MSB MUST BE 0!
    SPI_Transfer(value);
    GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_4, GPIO_PIN_SET);   // CS HIGH
}

void BMP280_ReadRegisters(uint8_t reg, uint8_t *buffer, uint8_t len)
{
    GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_4, GPIO_PIN_RESET); // CS LOW
    SPI_Transfer(reg | 0x80); // Read Mode: MSB MUST BE 1!
    for(uint8_t i = 0; i < len; i++) {
        buffer[i] = SPI_Transfer(0x00); // Send dummy bytes to clock in data
    }
    GPIO_WriteToOutputPin(GPIOA, GPIO_PIN_NO_4, GPIO_PIN_SET);   // CS HIGH
}
