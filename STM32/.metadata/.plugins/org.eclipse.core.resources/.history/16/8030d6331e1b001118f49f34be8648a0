/**********************************GPIO Port Code Macro **********************************/

/*
 * This macro returns a code (between 0 to 7) for a given GPIO base address (x)
 * STM32F446xx has GPIO ports A-H only
 */
#define GPIO_BASEADDR_TO_CODE(x)            ( (x == GPIOA) ? 0 :\
                                              (x == GPIOB) ? 1 :\
                                              (x == GPIOC) ? 2 :\
                                              (x == GPIOD) ? 3 :\
                                              (x == GPIOE) ? 4 :\
                                              (x == GPIOF) ? 5 :\
                                              (x == GPIOG) ? 6 :\
                                              (x == GPIOH) ? 7 : 0 )


