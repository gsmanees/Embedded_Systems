#include <stdint.h>
#include "stm32f446xx.h"
#include "stm32f446xx_gpio_driver.h"

#define LED1 GPIO_PIN_NO_6
#define LED2 GPIO_PIN_NO_7

void delay(void)
{
	for(int i=0; i<500000; i++);
}


int main(void)
{
	// declare handles
	GPIO_Handle_t led1_handle;
	GPIO_Handle_t led2_handle;

	// configure LED1
	led1_handle.pGPIOx = GPIOA;
	led1_handle.GPIO_PinConfig.GPIO_PinNumber = LED1;
	led1_handle.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;


	// configure LED2
	led2_handle.pGPIOx = GPIOA;
	led2_handle.GPIO_PinConfig.GPIO_PinNumber = LED2;
	led2_handle.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;


	// initialise handles
	GPIO_Init(&led1_handle);
	GPIO_Init(&led2_handle);

	// clock enable
	GPIO_PeriClockControl(GPIOA, ENABLE);


	while(1)
	{
		GPIO_WriteToOutputPin(GPIOA, LED1, 1);
		GPIO_WriteToOutputPin(GPIOA, LED2, 0);
		delay();
		GPIO_WriteToOutputPin(GPIOA, LED1, 0);
		GPIO_WriteToOutputPin(GPIOA, LED2, 1);
		delay();

	}






}
