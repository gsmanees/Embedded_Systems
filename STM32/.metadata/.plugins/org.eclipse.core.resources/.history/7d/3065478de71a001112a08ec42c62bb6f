#include <stdint.h>
#include "stm32f446xx.h"
#include "stm32f446xx_gpio_driver.h"

#define LED GPIO_PIN_NO_5
#define BUTTON GPIO_PIN_NO_13

delay()
{
	for(int i=0; i<300000; i++);
}

int main(void)
{
	int led_state=0;
	GPIO_Handle_t led;
	GPIO_Handle_t button;

	// led configuration
	led.pGPIOx = GPIOA;
	led.GPIO_PinConfig.GPIO_PinNumber = LED;
	led.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;

	// button configuration
	button.pGPIOx = GPIOC;
	button.GPIO_PinConfig.GPIO_PinNumber = BUTTON;
	button.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_IN;

	// intialise handles
	GPIO_Init(&led);
	GPIO_Init(&button);

	// clock enable
	GPIO_PeriClockControl(GPIOA, ENABLE);
	GPIO_PeriClockControl(GPIOC, ENABLE);

	while(1)
	{
		if(GPIO_ReadFromInputPin(GPIOC, BUTTON) == 0)
		{
			delay();
			GPIO_WriteToOutputPin(GPIOA, LED, led_state);
			led_state = !led_state;
		}
	}


}
