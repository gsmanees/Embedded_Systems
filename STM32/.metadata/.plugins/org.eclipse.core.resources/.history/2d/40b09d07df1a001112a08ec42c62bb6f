#include <stdint.h>
#include "stm32f446xx.h"
#include "stm32f446xx_gpio_driver.h"



void delay (void)
{
		for(int i=0;i<5000;i++);
}

int main(void)
{

	GPIO_Handle_t led;
	led.pGPIOx = GPIOA;
	led.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_5;
	led.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;

	while(1)
	{
		GPIO_ToggleOutputPin(pGPIOA, LED);
		delay();
	}

}
